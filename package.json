{
  "name": "clidocs",
  "version": "0.1.0",
  "description": "Real-time CLI documentation from GitHub repos",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun wrangler dev",
    "deploy": "bun wrangler deploy",
    "typecheck": "bun tsc --noEmit",
    "lint": "bun oxlint",
    "lint:prod": "bun oxlint src",
    "format": "bun oxfmt",
    "format:prod": "bun oxfmt --check src"
  },
  "dependencies": {
    "@cloudflare/workers-types": "4.20260615.1"
  },
  "devDependencies": {
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "typescript": "6.0.3",
    "wrangler": "4.100.0"
  }
}
